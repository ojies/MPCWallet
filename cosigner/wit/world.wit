package component:threshold@0.1.0;

interface types {
    /// Error type for threshold operations.
    variant threshold-error {
        invalid-input(string),
        crypto-error(string),
        serialization-error(string),
    }

    /// Opaque handle for DKG round 1 secret state.
    resource round1-secret {}

    /// Opaque handle for DKG round 2 secret state.
    resource round2-secret {}

    /// Opaque handle for a signing nonce (single-use).
    resource signing-nonce {}

    // -----------------------------------------------------------------------
    // Session state resources — all user data lives in WASM linear memory
    // -----------------------------------------------------------------------

    /// DKG session state: round packages, identifiers, server state, relay.
    resource dkg-session {
        constructor();
        reset: func();

        // Round 1 packages
        insert-round1-package: func(id-hex: string, pkg-json: string);
        insert-receiver-identifier: func(id-hex: string);
        total-participants: func() -> u32;
        is-receiver: func(id-hex: string) -> bool;
        get-round1-packages-json: func() -> string;
        get-round1-packages-excluding-json: func(exclude-id-hex: string) -> string;
        get-receiver-ids-json: func() -> string;

        // Server identity
        set-server-id: func(server-id-hex: string);
        get-server-id: func() -> string;
        set-server-internal-secret-hex: func(secret-hex: string);
        get-server-internal-secret-hex: func() -> string;

        // Round 2 received
        insert-round2-received: func(sender-id-hex: string, pkg-json: string);
        get-round2-received-json: func() -> string;

        // Round 2 local (server's own)
        set-round2-local-json: func(json: string);
        get-round2-local-json: func() -> string;
        is-round2-local-empty: func() -> bool;

        // Round 2 relay: sender -> { recipient -> pkg }
        insert-relay-packages: func(sender-id-hex: string, packages-json: string);
        insert-relay-from-local: func(server-id-hex: string);
        relay-sender-count: func() -> u32;
        get-relay-packages-for: func(recipient-id-hex: string) -> string;
    }

    /// Signing session state: commitments, shares, message, policy metadata.
    resource signing-session {
        constructor();
        reset: func();

        // User commitments
        set-user-hiding-hex: func(hex: string);
        get-user-hiding-hex: func() -> string;
        set-user-binding-hex: func(hex: string);
        get-user-binding-hex: func() -> string;

        // Message
        set-message-to-sign: func(msg-hex: string);
        get-message-to-sign: func() -> string;
        has-message: func() -> bool;

        // Server commitments
        set-server-commitments-json: func(json: string);
        get-server-commitments-json: func() -> string;
        has-server-commitments: func() -> bool;

        // Commitment list: id -> commitments_json
        insert-commitment: func(id-hex: string, commitments-json: string);
        get-commitments-json: func() -> string;

        // Signature shares: id -> share_hex
        insert-share: func(id-hex: string, share-hex: string);
        has-share: func(id-hex: string) -> bool;
        share-count: func() -> u32;
        get-shares-json: func() -> string;

        // Policy metadata
        set-current-policy-id: func(id: string);
        get-current-policy-id: func() -> string;
        set-pending-amount: func(amount: s64);
        get-pending-amount: func() -> s64;
    }

    /// Refresh (re-DKG) session state: round packages, relay, policy metadata.
    resource refresh-session {
        constructor();
        reset: func();

        // Round 1 packages
        insert-round1-package: func(id-hex: string, pkg-json: string);
        round1-count: func() -> u32;
        get-round1-packages-json: func() -> string;
        get-round1-packages-excluding-json: func(exclude-id-hex: string) -> string;

        // Server identity
        set-server-id: func(server-id-hex: string);
        get-server-id: func() -> string;
        set-server-identifier-hex: func(id-hex: string);
        get-server-identifier-hex: func() -> string;

        // Round 2 received
        insert-round2-received: func(sender-id-hex: string, pkg-json: string);
        get-round2-received-json: func() -> string;

        // Round 2 local
        set-round2-local-json: func(json: string);
        get-round2-local-json: func() -> string;
        is-round2-local-empty: func() -> bool;

        // Round 2 relay
        insert-relay-packages: func(sender-id-hex: string, packages-json: string);
        insert-relay-from-local: func(server-id-hex: string);
        relay-sender-count: func() -> u32;
        get-relay-packages-for: func(recipient-id-hex: string) -> string;

        // Refresh policy metadata
        set-refresh-creation-time-ms: func(ms: s64);
        get-refresh-creation-time-ms: func() -> s64;
        set-refresh-id: func(id: string);
        get-refresh-id: func() -> string;
        set-refresh-threshold-amount: func(amount: s64);
        get-refresh-threshold-amount: func() -> s64;
        set-refresh-interval: func(interval: s64);
        get-refresh-interval: func() -> s64;
    }

    /// Opaque handle for an auth signer (reusable).
    resource auth-signer {
        /// Create an AuthSigner from a 64-char hex secret key.
        /// Returns the compressed public key hex (66 chars).
        constructor(secret-hex: string);

        /// Sign a message. Returns signature hex (128 chars).
        sign: func(message: list<u8>) -> result<string, threshold-error>;

        /// Get the compressed public key hex (66 chars).
        public-key: func() -> result<string, threshold-error>;
    }

    /// DKG round 1 output.
    record dkg-round1-output {
        round1-package-json: string,
        secret: round1-secret,
    }

    /// DKG refresh round 1 output (includes coefficients for polynomial eval).
    record dkg-refresh-round1-output {
        round1-package-json: string,
        coefficients-json: string,
        secret: round1-secret,
    }

    /// DKG round 2 output.
    record dkg-round2-output {
        round2-packages-json: string,
        secret: round2-secret,
    }

    /// DKG round 3 output (final keys).
    record dkg-round3-output {
        key-package-json: string,
        public-key-package-json: string,
    }

    /// Nonce generation output.
    record nonce-output {
        commitments-json: string,
        nonce: signing-nonce,
    }

    /// Threshold cryptography operations.
    resource threshold-session {
        constructor();

        // ----- DKG -----

        /// DKG round 1: generate secret polynomial, commitment, proof-of-knowledge.
        dkg-part1: func(max-signers: u32, min-signers: u32,
            secret-hex: string, coefficients-json: string)
            -> result<dkg-round1-output, threshold-error>;

        /// DKG round 2: verify round 1 packages and compute shares.
        dkg-part2: func(secret: round1-secret,
            round1-packages-json: string, receiver-ids-json: string)
            -> result<dkg-round2-output, threshold-error>;

        /// DKG round 3: verify shares, compute final key package.
        dkg-part3: func(r2-secret: round2-secret,
            round1-packages-json: string, round2-packages-json: string,
            receiver-ids-json: string)
            -> result<dkg-round3-output, threshold-error>;

        /// DKG round 3 for a passive receiver (no secret polynomial).
        dkg-part3-receive: func(my-id-hex: string,
            dealer-r1-json: string, shares-json: string,
            min-signers: u32, max-signers: u32, all-ids-json: string)
            -> result<dkg-round3-output, threshold-error>;

        // ----- Key Refresh -----

        /// Key refresh round 1: zero-secret polynomial for share rotation.
        dkg-refresh-part1: func(id-hex: string, max-signers: u32,
            min-signers: u32, seed: list<u8>)
            -> result<dkg-refresh-round1-output, threshold-error>;

        /// Key refresh round 2: compute refresh shares.
        dkg-refresh-part2: func(secret: round1-secret,
            round1-packages-json: string)
            -> result<dkg-round2-output, threshold-error>;

        /// Key refresh round 3: combine with old keys.
        dkg-refresh-part3: func(r2-secret: round2-secret,
            round1-packages-json: string, round2-packages-json: string,
            old-pkp-json: string, old-kp-json: string)
            -> result<dkg-round3-output, threshold-error>;

        // ----- Signing -----

        /// Generate a signing nonce pair from the signer's secret share.
        new-nonce: func(secret-hex: string)
            -> result<nonce-output, threshold-error>;

        /// Compute a FROST signature share.
        frost-sign: func(signing-package-json: string,
            nonce: signing-nonce, key-package-json: string)
            -> result<string, threshold-error>;

        /// Aggregate signature shares into final signature.
        frost-aggregate: func(signing-package-json: string,
            shares-json: string, public-key-package-json: string)
            -> result<string, threshold-error>;

        // ----- Key Operations -----

        /// Apply taproot tweak to a KeyPackage.
        key-package-tweak: func(kp-json: string, merkle-root: option<list<u8>>)
            -> result<string, threshold-error>;

        /// Apply taproot tweak to a PublicKeyPackage.
        pub-key-package-tweak: func(pkp-json: string, merkle-root: option<list<u8>>)
            -> result<string, threshold-error>;

        /// Normalize KeyPackage to even Y (BIP-340).
        key-package-into-even-y: func(kp-json: string)
            -> result<string, threshold-error>;

        /// Normalize PublicKeyPackage to even Y (BIP-340).
        pub-key-package-into-even-y: func(pkp-json: string)
            -> result<string, threshold-error>;

        // ----- Auth -----

        /// Verify a BIP-340 Schnorr signature.
        verify-schnorr-signature: func(pk-hex: string,
            message: list<u8>, sig-hex: string)
            -> result<bool, threshold-error>;

        // ----- Utils -----

        /// Derive an identifier from arbitrary bytes (SHA-256).
        identifier-derive: func(message: list<u8>)
            -> result<string, threshold-error>;

        /// Create identifier from BigInt hex scalar.
        identifier-from-bigint: func(hex-str: string)
            -> result<string, threshold-error>;

        /// Generate random coefficients (seeded if seed non-empty).
        generate-coefficients: func(count: u32, seed: list<u8>)
            -> result<string, threshold-error>;

        /// Evaluate polynomial at identifier.
        evaluate-polynomial: func(id-hex: string, coefficients-json: string)
            -> result<string, threshold-error>;

        /// Generate a random non-zero scalar mod n.
        mod-n-random: func() -> result<string, threshold-error>;

        /// Scalar * G (base point multiplication).
        elem-base-mul: func(scalar-hex: string)
            -> result<string, threshold-error>;
    }
}

world threshold-world {
    export types;
}
